---
import Layout from './Layout.astro';
const { frontmatter = {} } = Astro.props;
const title = frontmatter?.title || '友情链接';
const friends = frontmatter?.friends || [];
---

<style is:global>
  /* 友链卡片网格布局 */
  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 15px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px dashed #ccc;
  }

  /* Win7 列表项拟物风格卡片 */
  .friend-card {
    display: flex;
    align-items: center;
    padding: 10px;
    background: linear-gradient(to bottom, #ffffff, #f4f5f6);
    border: 1px solid #abadb3;
    border-radius: 3px;
    text-decoration: none;
    color: inherit;
    box-shadow: 1px 1px 3px rgba(0,0,0,0.05), inset 0 1px 0 #fff;
    transition: all 0.1s ease-in-out;
  }

  .friend-card:hover {
    background: linear-gradient(to bottom, #eaf6fd, #d9f0fc);
    border-color: #3c7fb1;
    box-shadow: 1px 1px 4px rgba(0,0,0,0.1), inset 0 1px 0 rgba(255,255,255,0.8);
  }

  .friend-card:active {
    background: linear-gradient(to bottom, #e5f4fc, #c4e5f6);
    border-color: #2c628b;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);
  }

  /* 拍立得质感头像 */
  .friend-avatar {
    width: 48px;
    height: 48px;
    border-radius: 2px;
    border: 1px solid #abadb3;
    padding: 2px;
    background: #fff;
    margin-right: 12px;
    flex-shrink: 0;
    object-fit: cover;
  }

  .friend-info {
    flex: 1;
    overflow: hidden;
  }

  .friend-name {
    font-weight: bold;
    color: #003366;
    font-size: 14px;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .friend-desc {
    font-size: 11px;
    color: #666;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

/* ========== 留言板净化样式 (复用你之前的设定 + 隐藏登录按钮 + 暴力干掉 SVG) ========== */
  #waline .wl-empty, #waline .wl-rss, #waline .wl-power, #waline .wl-meta-head, #waline .wl-actions, #waline .wl-word-count, #waline .wl-text-number, #waline .wl-close, #waline .wl-login { display: none !important; }
  #waline { font-family: 'Segoe UI', Tahoma, sans-serif !important; padding-left: 0 !important; }
  #waline .wl-panel { margin: 0 !important; padding: 0 !important; border: none !important; background: transparent !important; box-shadow: none !important; }
  #waline .wl-header { display: flex !important; gap: 8px !important; border: none !important; background: transparent !important; padding: 0 !important; margin: 0 0 10px 0 !important; align-items: stretch !important; }
  #waline .wl-header-item { flex: 1 !important; padding: 0 !important; border: none !important; }
  #waline .wl-header-item label { display: none !important; }
  #waline .wl-header-item input, #waline .wl-editor { width: 100% !important; box-sizing: border-box !important; border: 1px solid #abadb3 !important; border-radius: 1px !important; padding: 5px 8px !important; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1) !important; background: #fff !important; color: #333 !important; font-family: 'Segoe UI', Tahoma, sans-serif !important; font-size: 12px !important; outline: none !important; }
  #waline .wl-editor { min-height: 100px !important; resize: vertical !important; margin: 0 !important; display: block !important; }
  #waline .wl-header-item input:hover, #waline .wl-editor:hover { border-color: #7eb4ea !important; }
  #waline .wl-header-item input:focus, #waline .wl-editor:focus { border-color: #569de5 !important; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1), 0 0 3px rgba(86,157,229,0.4) !important; }
  #waline .wl-footer { margin: 10px 0 0 0 !important; padding: 0 !important; display: flex !important; justify-content: space-between !important; align-items: center !important; border: none !important; }
  #waline .wl-info { display: flex !important; gap: 8px !important; align-items: center !important; margin-left: auto !important; }
  #waline .wl-btn, #waline .wl-refresh { display: inline-flex !important; align-items: center; justify-content: center; background: linear-gradient(to bottom, #f2f2f2 0%, #ebebeb 49%, #dddddd 50%, #cfcfcf 100%) !important; border: 1px solid #707070 !important; border-radius: 3px !important; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.8) !important; padding: 3px 15px !important; color: #333 !important; font-family: 'Segoe UI', Tahoma, sans-serif !important; font-size: 12px !important; cursor: pointer !important; min-width: 75px !important; height: 24px !important; margin: 0 !important; }
  #waline .wl-refresh { margin-right: auto !important; }
  #waline .wl-btn:hover, #waline .wl-refresh:hover { background: linear-gradient(to bottom, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important; border-color: #3c7fb1 !important; }
  #waline .wl-btn:active, #waline .wl-refresh:active { background: linear-gradient(to bottom, #e5f4fc 0%, #c4e5f6 49%, #98d1ef 50%, #68b3db 100%) !important; border-color: #2c628b !important; box-shadow: inset 0 1px 2px rgba(0,0,0,0.2) !important; }
  #waline .wl-cards { margin-top: 25px !important; padding-top: 15px !important; border-top: 1px solid #c4d5e6 !important; }
  #waline .wl-card-item { padding: 12px 0 !important; border-bottom: 1px dashed #ccc !important; margin: 0 !important; }
  #waline .wl-card-item:last-child { border-bottom: none !important; }
  #waline .wl-user img { border-radius: 2px !important; border: 1px solid #abadb3 !important; padding: 2px !important; background: #fff !important; box-shadow: 1px 1px 3px rgba(0,0,0,0.1) !important; }
  #waline .wl-nick { color: #003366 !important; font-weight: bold !important; font-size: 13px !important; }
  #waline .wl-badge { background: #e4effa !important; border: 1px solid #70c0e7 !important; color: #003366 !important; border-radius: 2px !important; padding: 1px 4px !important; font-size: 10px !important; box-shadow: none !important; }
  #waline .wl-sys-badge { background: transparent !important; border: none !important; color: #888 !important; font-size: 11px !important; }
  #waline .wl-content { color: #333 !important; font-size: 13px !important; line-height: 1.6 !important; margin-top: 5px !important; padding-left: 0 !important; }
  #waline .wl-action { display: flex !important; gap: 6px !important; align-items: center !important; margin-top: 8px !important; }
  #waline .wl-action button { all: unset !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; box-sizing: border-box !important; min-width: 50px !important; height: 23px !important; padding: 0 8px !important; font-family: 'Segoe UI', Tahoma, sans-serif !important; font-size: 12px !important; color: #333 !important; cursor: pointer !important; background: linear-gradient(180deg, #f2f2f2 0%, #ebebeb 49%, #dddddd 50%, #cfcfcf 100%) !important; border: 1px solid #707070 !important; border-radius: 3px !important; box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.8) !important; }
  #waline .wl-action button:hover { background: linear-gradient(180deg, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important; border-color: #3c7fb1 !important; }
  #waline .wl-action button:active { background: linear-gradient(180deg, #e5f4fc 0%, #c4e5f6 49%, #98d1ef 50%, #68b3db 100%) !important; border-color: #2c628b !important; box-shadow: inset 0 1px 2px rgba(0,0,0,0.2) !important; }
  

</style>

<Layout title={title + " | AeroDreams"} showTOC={false}>
  
  <article class="window glass-panel" style="margin-bottom: 30px;">
    <div class="title-bar aero-title-bar">
      <div class="title-bar-text"><img src="/icon/112.png" style="width: 16px; margin-right: 5px; vertical-align: middle;">{title}</div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" disabled></button>
        <button aria-label="Maximize" class="btn-mobile-view"></button>
        <button aria-label="Close" class="btn-desktop-view"></button>
      </div>
    </div>
    
    <div class="window-body article-body" style="padding: 20px;">
      <main class="article-content" style="line-height: 1.8; color: #333;">
        <slot />
      </main>
      
      {friends.length > 0 && (
        <div class="friends-grid">
          {friends.map((friend: any) => (
            <a href={friend.url} target="_blank" class="friend-card" title={friend.desc}>
              <img src={friend.avatar} alt={friend.name} class="friend-avatar" onerror="this.src='/images/bwolf.png'" />
              <div class="friend-info">
                <div class="friend-name">{friend.name}</div>
                <div class="friend-desc">{friend.desc}</div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </article>

  <div class="window glass-panel" style="margin-bottom: 30px;">
    <div class="title-bar aero-title-bar">
      <div class="title-bar-text"><img src="/icon/014.png" style="width: 14px; margin-right: 5px; vertical-align: middle;"> 访客留言</div>
    </div>
    <div class="window-body" style="padding: 15px; margin: 0; background: #f0f0f0; border-top: 1px solid #fff;">
      <div id="waline"></div>
    </div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
  <script type="module">
    import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
    document.addEventListener('DOMContentLoaded', () => {
      init({
        el: '#waline',
        serverURL: 'https://waline.zlight106.top', 
        search: false, emoji: false, imageUploader: false 
      });

      const observer = new MutationObserver(() => {
        const nick = document.querySelector('.wl-header-item input[name="nick"]');
        const mail = document.querySelector('.wl-header-item input[name="mail"]');
        const link = document.querySelector('.wl-header-item input[name="link"]');
        const footerInfo = document.querySelector('#waline .wl-info');
        const refreshBtn = document.querySelector('#waline .wl-refresh');

        if (nick && !nick.placeholder) {
          nick.placeholder = '昵称 (必填)';
          if (mail) mail.placeholder = '邮箱 (必填)';
          if (link) link.placeholder = '个人网址 (选填)';
        }
        if (footerInfo && refreshBtn && refreshBtn.parentNode !== footerInfo) {
          refreshBtn.innerHTML = '刷新'; 
          footerInfo.prepend(refreshBtn);
        }
      });
      observer.observe(document.getElementById('waline'), { childList: true, subtree: true });
    });
  </script>
</Layout>