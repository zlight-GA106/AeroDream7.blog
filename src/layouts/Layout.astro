---
// 引入抽离出去的全局样式
import '../styles/global.css';

const { title = "AeroDreams | Astro" } = Astro.props;

// 1. 获取所有文章用于提取标签和计算总数
const allPosts = Object.values(import.meta.glob('../pages/posts/*.md', { eager: true }));
const tags = [...new Set(allPosts.map((post: any) => post.frontmatter.tags || []).flat())];

// 2. 站点状态统计逻辑
const postCount = allPosts.length;
// 假设你的建站日期是 2026-04-09，计算运行天数
const startDate = new Date('2026-04-09').getTime();
const today = new Date().getTime();
const runDays = Math.floor((today - startDate) / (1000 * 60 * 60 * 24));
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="stylesheet" href="/css/7.css/dist/7.css">
</head>
<body>
  <div id="aero-workspace">
    
    <aside class="sidebar-left" style="display: flex; flex-direction: column; gap: 20px;">
      
      <div class="window glass-panel">
        <div class="title-bar aero-title-bar">
          <div class="title-bar-text">
            <img src="/icon/014.png" style="width: 14px; margin-right: 4px; vertical-align: middle;"> 
            用户标识
          </div>
        </div>
        
        <div class="window-body" style="padding: 15px; text-align: center;">
          
          <div style="width: 80px; height: 80px; margin: 0 auto 10px auto; border: 2px solid rgba(255,255,255,0.8); border-radius: 8px; background: linear-gradient(135deg, #e0f7fa, #80deea); box-shadow: 0 4px 8px rgba(0,0,0,0.2), inset 0 1px 2px rgba(255,255,255,0.9); display: flex; align-items: center; justify-content: center;">
            <img src="/icon/054.png" style="width: 48px;">
          </div>
          <h3 style="margin: 5px 0; color: #003366; font-family: 'Segoe UI', Tahoma;">zlight106</h3>
          <p style="font-size: 11px; color: #555; margin: 5px 0 15px 0; border-top: 1px dashed #ccc; padding-top: 8px;">
            物联网应用 / 硬件 DIY / 赛博拾荒者
          </p>
          
          <div style="display: flex; gap: 8px; justify-content: center;">
            <a href="https://github.com/zlight106" target="_blank" class="aero-nav-btn" style="flex: 1; padding: 4px 0; font-size: 11px;">
              <img src="/icon/086.png" style="width: 12px; vertical-align: middle; margin-right: 3px;"> 源代码
            </a>
            <a href="/rss.xml" class="aero-nav-btn" style="flex: 1; padding: 4px 0; font-size: 11px;">
              <img src="/icon/071.png" style="width: 12px; vertical-align: middle; margin-right: 3px;"> RSS 订阅
            </a>
          </div>

        </div>
      </div>

      <div class="window glass-panel">
        <div class="title-bar aero-title-bar">
          <div class="title-bar-text">
            <img src="/icon/071.png" style="width: 14px; margin-right: 4px; vertical-align: middle;"> 
            系统探针
          </div>
        </div>
        <div class="window-body" style="padding: 15px;">
          <ul style="list-style: none; padding: 0; margin: 0; font-size: 12px; color: #333;">
            <li style="display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px dotted rgba(0,0,0,0.1); padding-bottom: 4px;">
              <span><img src="/icon/041.png" style="width: 12px; vertical-align: middle; margin-right: 4px;"> 归档总数:</span>
              <span style="font-weight: bold; color: #1e5799;">{postCount} 篇</span>
            </li>
            <li style="display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px dotted rgba(0,0,0,0.1); padding-bottom: 4px;">
              <span><img src="/icon/035.png" style="width: 12px; vertical-align: middle; margin-right: 4px;"> 运行时间:</span>
              <span style="font-weight: bold; color: #1e5799;">{runDays} 天</span>
            </li>
            <li style="display: flex; justify-content: space-between;">
              <span><img src="/icon/028.png" style="width: 12px; vertical-align: middle; margin-right: 4px;"> 当前状态:</span>
              <span style="font-weight: bold; color: #006600;">Online (正常)</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="window glass-panel">
        <div class="title-bar aero-title-bar">
          <div class="title-bar-text">
            <img src="/icon/017.png" style="width: 14px; margin-right: 4px; vertical-align: middle;"> 
            环境常量 (Tags)
          </div>
        </div>
        <div class="window-body" style="padding: 15px; display: flex; flex-wrap: wrap; gap: 8px;">
          {tags.map((tag) => (
            <a href="#" class="aero-tag-btn">{tag as string}</a>
          ))}
        </div>
      </div>

    </aside>

    <main class="main-content">
      <slot />
    </main>

    <aside class="sidebar-right">
      <div class="window glass-panel">
        <div class="title-bar aero-title-bar">
          <div class="title-bar-text">
            <img src="/icon/068.png" style="width: 14px; margin-right: 4px; vertical-align: middle;"> 
            控制面板
          </div>
        </div>
        <div class="window-body" style="display: flex; flex-direction: column; gap: 8px; padding: 15px;">
          <a href="/" class="aero-nav-btn">
            <img src="/icon/021.png" style="width: 14px; margin-right: 6px; vertical-align: middle;">Home
          </a>
          <a href="/archives" class="aero-nav-btn">
            <img src="/icon/022.png" style="width: 14px; margin-right: 6px; vertical-align: middle;">Archives
          </a>
        </div>
      </div>
    </aside>
  </div>
</body>
</div>
<script>
    document.addEventListener('DOMContentLoaded', () => {

      // ================= 1. 布局模式切换逻辑 (手机/桌面) =================
      const mobileBtns = document.querySelectorAll('.btn-mobile-view');
      const desktopBtns = document.querySelectorAll('.btn-desktop-view');

      mobileBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          document.body.classList.add('mode-mobile');
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });

      desktopBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          document.body.classList.remove('mode-mobile');
        });
      });

      // ================= 2. 代码块一键复制逻辑 =================
      const codeBlocks = document.querySelectorAll('pre');

      codeBlocks.forEach((block) => {
        // 创建一个“绝对静止”的外部包裹框 (Wrapper)
        const wrapper = document.createElement('div');
        wrapper.style.position = 'relative';
        
        // 将原本的代码块用这个外框包起来
        block.parentNode.insertBefore(wrapper, block);
        wrapper.appendChild(block);

        // 动态生成按钮
        const copyButton = document.createElement('button');
        copyButton.className = 'copy-code-btn';
        copyButton.textContent = '复制'; // 纯文字，拒绝 Emoji

        // 绑定点击事件
        copyButton.addEventListener('click', async () => {
          const codeText = block.querySelector('code')?.innerText || block.innerText;

          try {
            await navigator.clipboard.writeText(codeText);
            
            // 视觉反馈只改变文字
            copyButton.textContent = '已复制';

            // 2 秒后恢复原状
            setTimeout(() => {
              copyButton.textContent = '复制';
            }, 2000);
          } catch (err) {
            console.error('复制失败!', err);
            copyButton.textContent = '失败';
          }
        });

        // 把按钮挂载到“静止的外框(wrapper)”上
        wrapper.appendChild(copyButton);
      });

      // ================= 3. 新增：图片单击放大逻辑 (Aero Glass 风格) =================
      const articleImages = document.querySelectorAll('.article-body img');

      articleImages.forEach((img) => {
        img.addEventListener('click', () => {
          // 1. 创建模态框元素
          const modal = document.createElement('div');
          modal.className = 'zoomed-image-modal';

          // 2. 创建放大后的图片元素，并设置原图片的 src
          const zoomedImg = document.createElement('img');
          zoomedImg.src = img.src;
          if (img.alt) zoomedImg.alt = img.alt;

          // 3. 将图片放入模态框
          modal.appendChild(zoomedImg);

          // 4. 将模态框添加到页面 body 末尾
          document.body.appendChild(modal);

          // 5. 灵魂修复：禁止页面滚动，聚焦放大图片
          document.body.style.overflow = 'hidden';

          // 6. Aero 魔法：平滑淡入
          requestAnimationFrame(() => {
            modal.classList.add('show');
          });

          // 7. 绑定关闭事件：点击模态框任何位置
          modal.addEventListener('click', () => {
            // 平滑淡出
            modal.classList.remove('show');
            // 动画完成后从页面中彻底移除模态框元素
            modal.addEventListener('transitionend', () => {
                modal.remove();
                // 恢复页面滚动
                document.body.style.overflow = '';
            }, { once: true });
          });

          // 8. 绑定 Esc 键关闭事件
          const handleEsc = (event) => {
            if (event.key === 'Escape') {
              modal.click(); // 模拟点击模态框关闭
              window.removeEventListener('keydown', handleEsc); // 移除监听器
            }
          };
          window.addEventListener('keydown', handleEsc);

        });
      });

    });
  </script>
</body>
</html>
</body>
</html>
</html>