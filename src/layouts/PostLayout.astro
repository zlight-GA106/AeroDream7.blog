---
import Layout from './Layout.astro';
const { frontmatter = {}, headings = [] } = Astro.props;
const title = frontmatter?.title || '无标题系统日志';
const author = frontmatter?.author || 'zlight106'; 

const rawDate = frontmatter?.date || frontmatter?.created_at || frontmatter?.pubDate || '2000-01-01';
const pubDateObj = new Date(rawDate);
const year = pubDateObj.getFullYear();
const month = String(pubDateObj.getMonth() + 1).padStart(2, '0');
const day = String(pubDateObj.getDate()).padStart(2, '0');
const pubDateString = `${year}-${month}-${day}`; 
const pubDate = new Date(pubDateString);

const today = new Date();
const diffTime = Math.abs(today.getTime() - pubDate.getTime());
const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
const articleUrl = Astro.url.href;
const tags = frontmatter?.tags || [];
const isNovel = Array.isArray(tags) ? tags.includes('小说') : tags === '小说';
const isAboutPage = Astro.url.pathname.includes('/about');
const showWarning = !isNovel && !isAboutPage;
const showTOC = !isNovel && !isAboutPage && headings.length > 0;
---

<style is:global>
  /* ================= 1. 彻底清除多余元素 (含登录和取消回复) ================= */
  #waline .wl-empty, #waline .wl-rss, 
  #waline .wl-power, #waline .wl-meta-head, #waline .wl-actions, 
  #waline .wl-word-count, #waline .wl-text-number,
  #waline .wl-close, #waline .wl-login {
    display: none !important;
  }

  /* ================= 2. 容器重置 ================= */
  #waline { 
    font-family: 'Segoe UI', Tahoma, sans-serif !important;
    padding-left: 0 !important; 
  }

  #waline .wl-panel { 
    margin: 0 !important; 
    padding: 0 !important; 
    border: none !important; 
    background: transparent !important; 
    box-shadow: none !important; 
  }

  /* ================= 3. 输入框与编辑器 (7.css 强迫症对齐版) ================= */
  #waline .wl-header {
    display: flex !important;
    gap: 8px !important;
    border: none !important;
    margin: 0 0 10px 0 !important;
    padding: 0 !important; /* 强制去内边距 */
    width: 100% !important; /* 强制满宽，对齐下方的 editor */
    box-sizing: border-box !important;
  }

  #waline .wl-header-item { 
    flex: 1 !important; 
    margin: 0 !important; /* 抹杀所有默认外边距 */
    padding: 0 !important; 
    border: none !important; 
    min-width: 0 !important; /* 防止内部 input 过长撑破容器 */
  }

  #waline .wl-header-item label { display: none !important; }

  #waline .wl-header-item input,
  #waline .wl-editor {
    width: 100% !important;
    max-width: 100% !important; /* 锁定最大宽度 */
    box-sizing: border-box !important; /* 边框计算在宽度内，保证像素级精准 */
    border: 1px solid #abadb3 !important;
    border-radius: 1px !important;
    padding: 5px 8px !important;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.1) !important;
    background: #fff !important;
    font-size: 12px !important;
    outline: none !important;
    margin: 0 !important; /* 强制去除浏览器默认外边距 */
    display: block !important; /* 强制块级元素，消灭行内元素的缝隙 */
  }

  #waline .wl-header-item input {
    height: 28px !important; /* 强制固定头部输入框高度 */
  }

  #waline .wl-editor { 
    min-height: 100px !important; 
    height: auto !important; 
    resize: vertical !important; 
  }
  
  #waline .wl-header-item input:hover, #waline .wl-editor:hover { border-color: #7eb4ea !important; }
  #waline .wl-header-item input:focus, #waline .wl-editor:focus {
    border-color: #569de5 !important;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.1), 0 0 3px rgba(86,157,229,0.4) !important;
  }

  /* ================= 4. 底部按钮区 (发送/刷新) ================= */
  #waline .wl-footer {
    margin: 10px 0 0 0 !important;
    display: flex !important;
    justify-content: space-between !important; 
    align-items: center !important;
    border: none !important;
  }

  #waline .wl-btn, #waline .wl-refresh {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, #f2f2f2 0%, #ebebeb 49%, #dddddd 50%, #cfcfcf 100%) !important;
    border: 1px solid #707070 !important;
    border-radius: 3px !important;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.8) !important;
    padding: 3px 15px !important;
    color: #333 !important;
    font-size: 12px !important;
    cursor: pointer !important;
    height: 24px !important;
  }

  #waline .wl-btn:hover, #waline .wl-refresh:hover {
    background: linear-gradient(to bottom, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important;
    border-color: #3c7fb1 !important;
  }

  /* ================= 5. 评论内容展示区 ================= */
  #waline .wl-cards {
    margin-top: 25px !important;
    padding-top: 15px !important;
    border-top: 1px solid #c4d5e6 !important; 
  }

  #waline .wl-card-item { padding: 12px 0 !important; border-bottom: 1px dashed #ccc !important; }

  #waline .wl-user img {
    border-radius: 2px !important;
    border: 1px solid #abadb3 !important;
    padding: 2px !important;
    background: #fff !important;
  }

  #waline .wl-nick { color: #003366 !important; font-weight: bold !important; }

  /* ================= 6. 终极净化：点赞/回复 (PNG 图标版) ================= */
  #waline .wl-action {
    display: flex !important;
    gap: 6px !important;
    align-items: center !important;
    margin-top: 8px !important;
  }

  #waline .wl-action button {
    all: unset !important; 
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-sizing: border-box !important;
    min-width: 50px !important;
    height: 23px !important;
    padding: 0 8px !important;
    font-size: 12px !important;
    color: #333 !important;
    cursor: pointer !important;
    background: linear-gradient(180deg, #f2f2f2 0%, #ebebeb 49%, #dddddd 50%, #cfcfcf 100%) !important;
    border: 1px solid #707070 !important;
    border-radius: 3px !important;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.8) !important;
  }

  #waline .wl-action button:hover {
    background: linear-gradient(180deg, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important;
    border-color: #3c7fb1 !important;
  }

  #waline .wl-action svg, #waline .wl-like svg, #waline .wl-reply svg { display: none !important; }

  #waline .wl-like::before,
  #waline .wl-reply::before {
    content: '' !important; 
    display: inline-block !important;
    width: 14px !important; 
    height: 14px !important;
    margin-right: 4px !important; 
    background-size: contain !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    vertical-align: -2px !important; 
  }

  #waline .wl-like::before { background-image: url('/images/wheart.png') !important; }
  #waline .wl-like.active::before { background-image: url('/images/rheart.png') !important; }
  #waline .wl-reply::before { background-image: url('/images/guestbook.png') !important; }

  #waline .wl-like.active { color: #b30000 !important; font-weight: bold !important; }
</style>

<Layout title={title + " | AeroDreams"} showTOC={showTOC} headings={headings}>
  <article class="window glass-panel" style="margin-bottom: 30px;">
    <div class="title-bar aero-title-bar">
      <div class="title-bar-text"><img src="/icon/041.png" style="width: 16px; margin-right: 5px; vertical-align: middle;">{title}</div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" disabled></button>
        <button aria-label="Maximize" class="btn-mobile-view"></button>
        <button aria-label="Close" class="btn-desktop-view"></button>
      </div>
    </div>
    
    <div class="window-body article-body" style="padding: 20px;">
      <div style="color: #666; font-size: 11px; margin-bottom: 15px; border-bottom: 1px dashed #ccc; padding-bottom: 5px;">创建时间: {pubDateString}</div>

      {showWarning && (
        <div style="background: linear-gradient(to bottom, #ffffe9 0%, #fffdc9 100%); border: 1px solid #dfc778; border-radius: 3px; padding: 8px 10px; margin-bottom: 20px; font-size: 12px; color: #555; display: flex; align-items: center; box-shadow: inset 0 1px 0 rgba(255,255,255,1), 0 1px 2px rgba(0,0,0,0.05);">
          <span style="font-size: 16px; margin-right: 8px;">💡</span>
          <div>
            <strong>时效性提示：</strong>本文写于 <strong id="dynamic-days" data-date={pubDateString}>{diffDays}</strong> 天前。文中的配置或技术可能已发生变化，请注意甄别。
          </div>
        </div>
      )}

      <main class="article-content" style="line-height: 1.8; color: #333;"><slot /></main>

      {/* 修复区：强制图片内联、取消居中并强制左对齐容器 */}
      <div style="margin-top: 40px; background: linear-gradient(to bottom, #ffffe9 0%, #fffdc9 100%); border: 1px solid #dfc778; border-radius: 3px; padding: 15px; font-size: 12px; color: #555; box-shadow: inset 0 1px 0 rgba(255,255,255,1), 0 1px 2px rgba(0,0,0,0.05); font-family: 'Segoe UI', Tahoma, sans-serif; text-align: left;">
        <div style="font-weight: bold; color: #b27b08; margin-bottom: 12px; font-size: 13px;">
          <img src="/icon/069.png" style="width: 16px; height: 16px; margin: 0 5px 0 0 !important; display: inline-block !important; vertical-align: middle; filter: drop-shadow(0 1px 1px rgba(0,0,0,0.1));" alt="info"> 
          <span style="vertical-align: middle;">版权与许可协议</span>
        </div>
        <div style="line-height: 2;">
          <div style="display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 5px;">
            <div><strong>文章标题：</strong> {title}</div>
            <div><strong>本文作者：</strong> {author}</div>
          </div>
          <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 5px;">
            <strong>本文链接：</strong> 
            <input type="text" value={decodeURI(articleUrl)} readonly title="点击全选复制" onclick="this.select();" 
                   style="flex: 1; max-width: 450px; border: 1px solid #abadb3; border-radius: 2px; background: #fff; color: #333; padding: 3px 6px; font-size: 11px; font-family: Consolas, 'Courier New', monospace; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1); outline: none; cursor: text; margin: 0 !important;" />
          </div>
          <div><strong>授权协议：</strong> 本文采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans" target="_blank" style="color: #1e5799; text-decoration: underline;">CC BY-NC-SA 4.0</a> 许可协议。转载请注明原作者与出处。</div>
        </div>
      </div>

    </div>
  </article>

  <div class="window glass-panel" style="margin-bottom: 30px;">
    <div class="title-bar aero-title-bar">
      <div class="title-bar-text"><img src="/icon/014.png" style="width: 14px; margin-right: 5px; vertical-align: middle;"> 访客留言</div>
    </div>
    <div class="window-body" style="padding: 15px; margin: 0; background: #f0f0f0; border-top: 1px solid #fff;">
      <div id="waline"></div>
    </div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
  <script type="module">
    import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
    document.addEventListener('DOMContentLoaded', () => {
      init({
        el: '#waline',
        serverURL: 'https://waline.zlight106.top', 
        search: false, 
        emoji: false, 
        imageUploader: false,
        login: 'disable' /* 终极物理超度：配置级禁用登录按钮  */
      });

      const observer = new MutationObserver(() => {
        const nick = document.querySelector('.wl-header-item input[name="nick"]');
        const mail = document.querySelector('.wl-header-item input[name="mail"]');
        const link = document.querySelector('.wl-header-item input[name="link"]');
        const footerInfo = document.querySelector('#waline .wl-info');
        const refreshBtn = document.querySelector('#waline .wl-refresh');

        if (nick && !nick.placeholder) {
          nick.placeholder = '昵称 (必填)';
          if (mail) mail.placeholder = '邮箱 (必填)';
          if (link) link.placeholder = '个人网址 (选填)';
        }

        if (footerInfo && refreshBtn && refreshBtn.parentNode !== footerInfo) {
          refreshBtn.innerHTML = '刷新'; 
          footerInfo.prepend(refreshBtn);
        }
      });
      observer.observe(document.getElementById('waline'), { childList: true, subtree: true });
    });
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const daysElement = document.getElementById('dynamic-days');
      if (daysElement) {
        const pubDateStr = daysElement.getAttribute('data-date');
        const pubDate = new Date(pubDateStr);
        if (!isNaN(pubDate.getTime())) {
          const today = new Date();
          const diffTime = Math.abs(today - pubDate);
          const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
          daysElement.innerText = diffDays;
        }
      }
    });
  </script>
</Layout>