---
import Layout from '../layouts/Layout.astro';

// 获取所有文章
const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }));

// 时间格式化魔法
const getDate = (fm: any) => {
  const rawDate = fm.created_at || fm.date || '2000-01-01';
  return String(rawDate).split('T')[0];
};

// 按时间从新到旧排序
allPosts.sort((a: any, b: any) => new Date(getDate(b.frontmatter)).valueOf() - new Date(getDate(a.frontmatter)).valueOf());

// 提取所有文章的 URL，转成 JSON 字符串，准备传给“随机文章”按钮的 JS 逻辑
const postUrls = JSON.stringify(allPosts.map((post: any) => post.url));
---

<Layout title="系统主页 | AeroDreams">
  
  <div class="window glass-panel" style="margin-bottom: 25px; cursor: pointer; transition: transform 0.1s;" id="btn-random-post" data-urls={postUrls} title="点击随机抽取一篇系统日志">
    <div class="window-body" style="padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(to right, rgba(255,255,255,0.8), rgba(255,255,255,0.3)); border-radius: 6px;">
      <span style="font-weight: bold; color: #1e5799; font-size: 15px;">
        <img src="/icon/068.png" style="width: 18px; vertical-align: middle; margin-right: 8px;"> 
        随机系统日志 (Random Access)
      </span>
      <span style="color: #666; font-weight: bold; font-family: 'Consolas', monospace;">></span>
    </div>
  </div>

  {allPosts.map((post: any) => (
    <article class="window glass-panel" style="margin-bottom: 30px;">
      
      <div class="title-bar aero-title-bar">
        <div class="title-bar-text">
          <img src="/icon/041.png" style="width: 16px; vertical-align: middle; margin-right: 5px;">
          <a href={post.url} style="color: inherit; text-decoration: none;">{post.frontmatter.title}</a>
        </div>
        <div class="title-bar-controls">
          <button aria-label="Minimize" disabled></button>
          <button aria-label="Maximize" class="btn-mobile-view" title="强制切换手机视图"></button>
          <button aria-label="Close" class="btn-desktop-view" title="恢复电脑视图"></button>
        </div>
      </div>
      
      <div class="window-body article-body" style="padding: 20px;">
        
        <div style="display: flex; gap: 15px; font-size: 12px; color: #555; margin-bottom: 15px; border-bottom: 1px dashed rgba(0,0,0,0.15); padding-bottom: 10px; flex-wrap: wrap;">
          <span>
            <img src="/icon/035.png" style="width:12px; vertical-align: middle; margin-right:3px;"> {getDate(post.frontmatter)}
          </span>
          <span>
            <img src="/icon/017.png" style="width:12px; vertical-align: middle; margin-right:3px;"> 
            {post.frontmatter.tags ? post.frontmatter.tags[0] : (post.frontmatter.tag || '未分类')}
          </span>
          <span>
            <img src="/icon/086.png" style="width:12px; vertical-align: middle; margin-right:3px;"> 日志片段
          </span>
        </div>
        
        <div style="margin-bottom: 20px; color: #333; line-height: 1.6;">
          {post.frontmatter.description || "该系统日志暂无摘要，请点击右下角按钮挂载完整数据卷以查看详细内容..."}
        </div>
        
        <div style="text-align: right;">
          <a href={post.url} class="aero-nav-btn" style="display: inline-block; padding: 6px 18px; font-size: 12px;">
            挂载数据卷 (Read More)
          </a>
        </div>

      </div>
    </article>
  ))}

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const randomBtn = document.getElementById('btn-random-post');
      if (randomBtn) {
        // 增加一点按下的物理反馈
        randomBtn.addEventListener('mousedown', () => randomBtn.style.transform = 'scale(0.99)');
        randomBtn.addEventListener('mouseup', () => randomBtn.style.transform = 'scale(1)');
        
        randomBtn.addEventListener('click', function() {
          try {
            // 从 data-urls 属性中解析出所有的文章链接
            const urls = JSON.parse(this.getAttribute('data-urls'));
            if (urls && urls.length > 0) {
              // 随机抽取一个索引
              const randomIndex = Math.floor(Math.random() * urls.length);
              // 执行跳转
              window.location.href = urls[randomIndex];
            }
          } catch (e) {
            console.error('随机跃迁失败', e);
          }
        });
      }
    });
  </script>
</Layout>