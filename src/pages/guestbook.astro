---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
  /* ================= 1. 彻底清除多余元素 ================= */
  #waline .wl-empty, #waline .wl-rss, 
  #waline .wl-power, #waline .wl-meta-head, #waline .wl-actions, 
  #waline .wl-word-count, #waline .wl-text-number,
  #waline .wl-close, #waline .wl-login {
    display: none !important;
  }

  /* ================= 2. 容器重置 ================= */
  #waline { 
    font-family: 'Segoe UI', Tahoma, sans-serif !important;
    padding-left: 0 !important; 
  }

  #waline .wl-panel { 
    margin: 0 !important; 
    padding: 0 !important; 
    border: none !important; 
    background: transparent !important; 
    box-shadow: none !important; 
  }

  /* ================= 3. 输入框与编辑器 (7.css 强迫症对齐版) ================= */
  #waline .wl-header {
    display: flex !important;
    gap: 8px !important;
    border: none !important;
    margin: 0 0 10px 0 !important;
    padding: 0 !important; 
    width: 100% !important; 
    box-sizing: border-box !important;
  }

  #waline .wl-header-item { 
    flex: 1 !important; 
    margin: 0 !important; 
    padding: 0 !important; 
    border: none !important; 
    min-width: 0 !important; 
  }

  #waline .wl-header-item label { display: none !important; }

  #waline .wl-header-item input,
  #waline .wl-editor {
    width: 100% !important;
    max-width: 100% !important; 
    box-sizing: border-box !important; 
    border: 1px solid #abadb3 !important;
    border-radius: 1px !important;
    padding: 5px 8px !important;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.1) !important;
    background: #fff !important;
    color: #333 !important;
    font-size: 12px !important;
    outline: none !important;
    margin: 0 !important; 
    display: block !important; 
  }

  #waline .wl-header-item input { height: 28px !important; }
  #waline .wl-editor { min-height: 100px !important; height: auto !important; resize: vertical !important; }
  
  #waline .wl-header-item input:hover, #waline .wl-editor:hover { border-color: #7eb4ea !important; }
  #waline .wl-header-item input:focus, #waline .wl-editor:focus {
    border-color: #569de5 !important;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.1), 0 0 3px rgba(86,157,229,0.4) !important;
  }

  /* ================= 4. 底部按钮区 (发送/刷新) ================= */
  #waline .wl-footer {
    margin: 10px 0 0 0 !important;
    display: flex !important;
    justify-content: space-between !important; 
    align-items: center !important;
    border: none !important;
  }

  #waline .wl-info { display: flex !important; gap: 8px !important; align-items: center !important; margin-left: auto !important; }

  #waline .wl-btn, #waline .wl-refresh {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, #f2f2f2 0%, #ebebeb 49%, #dddddd 50%, #cfcfcf 100%) !important;
    border: 1px solid #707070 !important;
    border-radius: 3px !important;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.8) !important;
    padding: 3px 15px !important;
    color: #333 !important;
    font-size: 12px !important;
    cursor: pointer !important;
    height: 24px !important;
  }

  #waline .wl-refresh { margin-right: auto !important; }

  #waline .wl-btn:hover, #waline .wl-refresh:hover {
    background: linear-gradient(to bottom, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important;
    border-color: #3c7fb1 !important;
  }

  #waline .wl-btn:active, #waline .wl-refresh:active { 
    background: linear-gradient(to bottom, #e5f4fc 0%, #c4e5f6 49%, #98d1ef 50%, #68b3db 100%) !important; 
    border-color: #2c628b !important; 
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.2) !important; 
  }

  /* ================= 5. 评论内容展示区 ================= */
  #waline .wl-cards { margin-top: 25px !important; padding-top: 15px !important; border-top: 1px solid #c4d5e6 !important; }
  #waline .wl-card-item { padding: 12px 0 !important; border-bottom: 1px dashed #ccc !important; margin: 0 !important; }
  #waline .wl-card-item:last-child { border-bottom: none !important; }
  #waline .wl-user img { border-radius: 2px !important; border: 1px solid #abadb3 !important; padding: 2px !important; background: #fff !important; box-shadow: 1px 1px 3px rgba(0,0,0,0.1) !important; }
  #waline .wl-nick { color: #003366 !important; font-weight: bold !important; font-size: 13px !important; }
  #waline .wl-badge { background: #e4effa !important; border: 1px solid #70c0e7 !important; color: #003366 !important; border-radius: 2px !important; padding: 1px 4px !important; font-size: 10px !important; box-shadow: none !important; }
  #waline .wl-sys-badge { background: transparent !important; border: none !important; color: #888 !important; font-size: 11px !important; }
  #waline .wl-content { color: #333 !important; font-size: 13px !important; line-height: 1.6 !important; margin-top: 5px !important; padding-left: 0 !important; }

  /* ================= 6. 终极净化：纯净的按钮底框 (严丝合缝圆角版) ================= */
  #waline .wl-action, #waline .wl-comment-actions {
    display: flex !important;
    gap: 8px !important;
    align-items: center !important;
    margin-top: 8px !important;
  }

  #waline .wl-like, #waline .wl-reply {
    all: unset !important; 
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-sizing: border-box !important;
    height: 24px !important; 
    padding: 0 12px !important; 
    cursor: pointer !important;
    border-radius: 3px !important; /* 精准圆角 */
    overflow: hidden !important; /* 核心修复：防止悬停时毛玻璃溢出产生杂线 */
    position: relative !important;
    text-decoration: none !important; 
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.8) !important;
  }

  /* 点赞按钮 (基础灰色 Aero) */
  #waline .wl-like { background: linear-gradient(180deg, #f2f2f2 0%, #ebebeb 49%, #dddddd 50%, #cfcfcf 100%) !important; border: 1px solid #8e8f8f !important; }
  #waline .wl-like:hover { background: linear-gradient(180deg, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important; border-color: #3c7fb1 !important; }

  /* 回复按钮 (纯正蓝色 Aero，完美对齐图二效果图) */
  #waline .wl-reply { background: linear-gradient(180deg, #eaf6fd 0%, #d9f0fc 49%, #bee6fd 50%, #a7d9f5 100%) !important; border: 1px solid #3c7fb1 !important; }
  #waline .wl-reply:hover { background: linear-gradient(180deg, #cde8f9 0%, #b5dff8 49%, #92cbf1 50%, #7dbceb 100%) !important; border-color: #1e5799 !important; }

  /* 隐藏原生杂音与旧版占位符 */
  #waline .wl-like svg, #waline .wl-reply svg { display: none !important; }
  #waline .wl-like::before, #waline .wl-like::after, #waline .wl-reply::before, #waline .wl-reply::after { display: none !important; }
  #waline .wl-text { display: none !important; } 
  
  /* 数字样式 */
  #waline .wl-count { font-size: 12px !important; color: #666 !important; font-family: 'Segoe UI', Tahoma, sans-serif !important; margin-left: 2px !important; }
</style>

<Layout title="留言板 | AeroDreams" showTOC={false}>
  
  <div class="window glass-panel" style="margin-bottom: 30px;">
    <div class="title-bar aero-title-bar">
      <div class="title-bar-text">
        <img src="/icon/014.png" style="width: 14px; margin-right: 5px; vertical-align: middle;"> 访客留言板
      </div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" disabled></button>
        <button aria-label="Maximize" class="btn-mobile-view"></button>
        <button aria-label="Close" class="btn-desktop-view"></button>
      </div>
    </div>
    
    <div class="window-body" style="padding: 15px; margin: 0; background: #f0f0f0; border-top: 1px solid #fff;">
      <div id="waline"></div>
    </div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
  <script type="module">
    import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
    document.addEventListener('DOMContentLoaded', () => {
      init({
        el: '#waline',
        serverURL: 'https://waline.zlight106.top', 
        search: false, emoji: false, imageUploader: false,
        path: '/guestbook', // 👈 强制指定路径归档
        login: 'disable' // 👈 配置级禁用登录模块
      });

      // 强硬手段：DOM 物理级注入 (同步 postlayout 完美防爆版本)
      const observer = new MutationObserver(() => {
        // 1. 顶部输入框逻辑
        const nick = document.querySelector('.wl-header-item input[name="nick"]');
        const mail = document.querySelector('.wl-header-item input[name="mail"]');
        const link = document.querySelector('.wl-header-item input[name="link"]');
        const footerInfo = document.querySelector('#waline .wl-info');
        const refreshBtn = document.querySelector('#waline .wl-refresh');

        if (nick && !nick.placeholder) {
          nick.placeholder = '昵称 (必填)';
          if (mail) mail.placeholder = '邮箱 (必填)';
          if (link) link.placeholder = '个人网址 (选填)';
        }
        if (footerInfo && refreshBtn && refreshBtn.parentNode !== footerInfo) {
          refreshBtn.innerHTML = '刷新'; 
          footerInfo.prepend(refreshBtn);
        }

        // 2. 暴力植入：点赞与回复按钮文字图标
        const actionBtns = document.querySelectorAll('#waline .wl-like, #waline .wl-reply');
        actionBtns.forEach(btn => {
          // 防止无限循环插入
          if (!btn.dataset.aeroModded) {
            btn.dataset.aeroModded = 'true';
            
            const isLike = btn.classList.contains('wl-like');
            const isActive = btn.classList.contains('active');

            // 创建原生图片标签
            const icon = document.createElement('img');
            icon.className = 'aero-physical-icon';
            // 核心修复：如果图片加载失败（404），立刻隐藏这个图标，绝对不显示丑陋的边框！
            icon.onerror = function() { this.style.display = 'none'; };
            icon.style.cssText = 'width: 14px; height: 14px; margin-right: 4px; display: inline-block; vertical-align: middle; flex-shrink: 0; outline: none; border: none; background: transparent;';

            // 创建原生文本标签
            const text = document.createElement('span');
            text.className = 'aero-physical-text';
            text.style.cssText = 'font-size: 12px; margin-right: 4px; display: inline-block; vertical-align: middle; font-family: "Segoe UI", Tahoma, sans-serif;';

            if (isLike) {
              icon.src = isActive ? '/images/rheart.png' : '/images/wheart.png';
              text.innerText = '点赞';
              text.style.color = isActive ? '#b30000' : '#333';
              text.style.fontWeight = isActive ? 'bold' : 'normal';
              if(isActive) btn.querySelector('.wl-count').style.color = '#b30000';
            } else {
              icon.src = '/images/guestbook.png';
              text.innerText = '回复';
              text.style.color = '#333';
            }

            // 物理插入按钮最前面
            btn.prepend(text);
            btn.prepend(icon);
          } else {
            // 动态监听点赞按钮的状态变化（红心/灰心切换）
            if (btn.classList.contains('wl-like')) {
              const isActive = btn.classList.contains('active');
              const icon = btn.querySelector('.aero-physical-icon');
              const text = btn.querySelector('.aero-physical-text');
              const count = btn.querySelector('.wl-count');
              if (icon && text) {
                icon.src = isActive ? '/images/rheart.png' : '/images/wheart.png';
                text.style.color = isActive ? '#b30000' : '#333';
                text.style.fontWeight = isActive ? 'bold' : 'normal';
                if(count) count.style.color = isActive ? '#b30000' : '#666';
              }
            }
          }
        });
      });
      observer.observe(document.getElementById('waline'), { childList: true, subtree: true });
    });
  </script>
</Layout>