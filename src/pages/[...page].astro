---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// ================= 1. 开启 Astro 原生分页引擎 (核心防爆函数) =================
export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection('posts');
  allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
  return paginate(allPosts, { pageSize: 6 });
}

const { page } = Astro.props;

// ================= 2. 为全局检索保留全量数据 =================
const allPostsForSearch = await getCollection('posts');
const postUrls = JSON.stringify(allPostsForSearch.map(post => `/posts/${post.id}`));
const searchData = JSON.stringify(allPostsForSearch.map(post => ({
  title: post.data.title || '无标题日志',
  url: `/posts/${post.id}`
})));

const formatDate = (dateObj: any) => {
  if (!dateObj) return '2000-01-01';
  const d = new Date(dateObj);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

// ================= 3. 智能省略号分页算法 =================
const getPaginationGroup = (current: number, last: number) => {
  if (last <= 7) return Array.from({ length: last }, (_, i) => i + 1);
  if (current <= 4) return [1, 2, 3, 4, 5, '...', last];
  if (current >= last - 3) return [1, '...', last - 4, last - 3, last - 2, last - 1, last];
  return [1, '...', current - 1, current, current + 1, '...', last];
};
const paginationGroup = getPaginationGroup(page.currentPage, page.lastPage);
// =========================================================

// ================= 4. 标签图标哈希映射算法 =================
const getTagIcon = (str: string) => {
  if (!str) return '017'; // 如果没文字，返回默认图标
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = str.charCodeAt(i) + ((hash << 5) - hash);
  }
  const num = (Math.abs(hash) % 533) + 1; // 限制在 1 到 533 之间
  
  // ⚠️ 重点：因为你之前用的图标是 "041.png"、"017.png" 这种三位补零格式，
  // 所以我加了 padStart。如果你的文件名字真的就是 "1.png" 到 "533.png" (没有前面的0)，
  // 请把下面的 `.padStart(3, '0')` 删掉！
  return String(num).padStart(3, '0');
};
// =========================================================
---

<style>
  .aero-page-btn {
    min-width: 36px;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    transition: all 0.15s ease-in-out;
  }
  .aero-page-btn:not([disabled]):hover {
    background-color: rgba(80, 170, 240, 0.4) !important; 
    box-shadow: inset 0 0 6px rgba(255, 255, 255, 0.8), 0 0 4px rgba(80, 170, 240, 0.5) !important;
    border-color: #3c7fb1;
  }
  .aero-page-btn:not([disabled]):active {
    background-color: rgba(40, 130, 210, 0.6) !important;
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.3) !important;
  }
  .aero-page-btn.active-page {
    background: linear-gradient(to bottom, #e4effa 0%, #c1dbfc 100%) !important;
    border: 1px solid #70c0e7 !important;
    box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.9), inset -1px -1px 0 rgba(255, 255, 255, 0.4) !important;
    color: #003366 !important;
    font-weight: bold;
  }
</style>

<Layout title="嘿！这里是紫光的现代小窝">
  
  <div class="window glass-panel" style="margin-bottom: 25px;">
    <div class="title-bar aero-title-bar">
      <div class="title-bar-text">
        <img src="/icon/098.png" style="width: 14px; margin-right: 4px; vertical-align: middle;"> 全局检索
      </div>
    </div>
    <div class="window-body" style="padding: 15px;">
      <form action="/search" method="get" class="searchbox" style="margin: 0;" onsubmit="document.body.classList.add('is-loading')">
        <input type="search" name="q" id="search-input" placeholder="输入文章标题或关键字..." required autocomplete="off" />
        <button type="submit" aria-label="search" id="search-btn"></button>
      </form>
    </div>
  </div>

  <div class="window glass-panel" style="margin-bottom: 25px; cursor: pointer; transition: transform 0.1s;" id="btn-random-post" data-urls={postUrls}>
    <div class="window-body" style="padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(to right, rgba(255,255,255,0.8), rgba(255,255,255,0.3)); border-radius: 6px;">
      <span style="font-weight: bold; color: #1e5799; font-size: 15px;">
        <img src="/icon/041.png" style="width: 18px; vertical-align: middle; margin-right: 8px;"> 随机挑选一篇文章
      </span>
      <span style="color: #666; font-weight: bold;">></span>
    </div>
  </div>

  {page.data.map((post: any) => {
    const wordCount = post.body ? post.body.replace(/\s/g, '').length : 0;
    const readTime = Math.max(1, Math.ceil(wordCount / 400));
    
    // 只保留日期的提前计算
    const dateStr = formatDate(post.data.date);

    return (
      <article class="window glass-panel" style="margin-bottom: 30px;">
        <div class="title-bar aero-title-bar" style="position: relative;">
          <div class="title-bar-text">
            <img src={`/icon/${getTagIcon(post.data.title)}.png`} style="width: 16px; vertical-align: middle; margin-right: 5px;">
            <a href={`/posts/${post.id}`} style="color: inherit; text-decoration: none;" class="article-link">{post.data.title}</a>
          </div>
          <div role="tooltip" class="is-bottom is-left aero-balloon">{post.data.title}</div>
          <div class="title-bar-controls">
            <button aria-label="Minimize" disabled></button>
            <button aria-label="Maximize" class="btn-mobile-view" title="强制切换手机视图"></button>
            <button aria-label="Close" class="btn-desktop-view" title="恢复电脑视图"></button>
          </div>
        </div>
        <div class="window-body article-body" style="padding: 20px;">
          <div style="display: flex; gap: 10px; font-size: 12px; color: #333; flex-wrap: wrap; align-items: center; margin-bottom: 15px;">
            
            <span class="aero-badge">
              <img src={`/icon/${getTagIcon(dateStr)}.png`} style="width: 14px; margin-right: 6px; display: block;">
              {dateStr}
            </span>
            
            {post.data.tags && post.data.tags.map((tag: string) => (
              <span class="aero-badge">
                <img src={`/icon/${getTagIcon(tag)}.png`} style="width: 14px; margin-right: 6px; display: block;">
                {tag}
              </span>
            ))}

            {(!post.data.tags || post.data.tags.length === 0) && (
              <span class="aero-badge">
                <img src="/icon/017.png" style="width: 14px; margin-right: 6px; display: block;">
                未分类
              </span>
            )}
            
          </div>
          <div style="margin-bottom: 20px; color: #444; line-height: 1.6; border-top: 1px dashed rgba(0,0,0,0.1); padding-top: 15px;">
            {post.data.description || "该系统日志暂无摘要，请点击右下方按钮查看详细内容..."}
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div style="font-size: 12px; color: #888;">{wordCount} 字 &nbsp;|&nbsp; {readTime} 分钟</div>
            <a href={`/posts/${post.id}`} class="aero-nav-btn article-link" style="padding: 6px 18px; font-size: 12px;">详细阅读</a>
          </div>
        </div>
      </article>
    );
  })}

  {page.lastPage > 1 && (
    <div class="window glass-panel" style="margin-bottom: 30px;">
      <div class="title-bar aero-title-bar">
        <div class="title-bar-text">
          <img src="/icon/2.png" style="width: 14px; margin-right: 4px; vertical-align: middle;"> 页面导航 ({page.currentPage} / {page.lastPage})
        </div>
      </div>
      
      <div class="window-body" style="padding: 12px 15px; display: flex; justify-content: space-between; align-items: center; background: #f0f0f0;">
        
        <div style="display: flex; gap: 5px; align-items: center;">
          <button 
            class="aero-page-btn" 
            onclick={page.url.prev ? `window.location.href='${page.url.prev}'` : ''} 
            disabled={!page.url.prev}
            style="padding: 0 8px;"
          >
            上一页
          </button>

          {paginationGroup.map(num => {
            if (num === '...') {
              return <span style="padding: 0 4px; color: #666; font-weight: bold; letter-spacing: 1px; user-select: none;">...</span>;
            }
            const isActive = page.currentPage === num;
            return (
              <button 
                class={`aero-page-btn ${isActive ? 'active-page' : ''}`}
                onclick={`window.location.href='${num === 1 ? '/' : `/${num}`}'`}
                disabled={isActive}
              >
                {num}
              </button>
            );
          })}

          <button 
            class="aero-page-btn" 
            onclick={page.url.next ? `window.location.href='${page.url.next}'` : ''} 
            disabled={!page.url.next}
            style="padding: 0 8px;"
          >
            下一页
          </button>
        </div>

        <div style="display: flex; align-items: center; gap: 6px; font-size: 12px; color: #333;">
          <span>跳转到第 </span>
          <input 
            type="number" 
            id="jump-page-input" 
            min="1" 
            max={page.lastPage}
            value={page.currentPage} 
            style="width: 45px; margin: 0; padding: 2px;" 
          />
          <span> 页</span>
          <button id="jump-page-btn" class="aero-page-btn" style="min-width: 40px; padding: 0 8px;">跳转</button>
        </div>

      </div>
    </div>
  )}

  <div id="search-db" data-search={searchData} style="display: none;"></div>

  <script define:vars={{ maxPage: page.lastPage }}>
    document.addEventListener('DOMContentLoaded', () => {
      const jumpBtn = document.getElementById('jump-page-btn');
      const jumpInput = document.getElementById('jump-page-input');

      if (jumpBtn && jumpInput) {
        const executeJump = () => {
          let targetPage = parseInt(jumpInput.value);
          if (isNaN(targetPage) || targetPage < 1) targetPage = 1;
          if (targetPage > maxPage) targetPage = maxPage;
          
          document.body.classList.add('is-loading');
          window.location.href = targetPage === 1 ? '/' : `/${targetPage}`;
        };

        jumpBtn.addEventListener('click', executeJump);
        jumpInput.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            executeJump();
          }
        });
      }
    });
  </script>
</Layout>